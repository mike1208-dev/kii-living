---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import { company, dx } from '../data/site';
---

<Base title={`不動産DX | ${company.name}`} description="オンライン相談・オンライン内見・電子契約など、テクノロジーで不動産取引をなめらかに。来店不要でスピーディーなお取引を実現します。">
  <PageHero eyebrow={dx.eyebrow} title={dx.title} lead={dx.lead} image="/images/photos/service-03.jpg" />

  <!-- サブタイトル帯 -->
  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-6xl px-5 md:px-8">
      <p class="reveal text-xl md:text-2xl font-bold text-center" style="color: var(--navy);">
        {dx.subtitle}
      </p>
    </div>
  </section>

  <!-- 機能 -->
  <section class="pb-20 md:pb-28">
    <div class="mx-auto max-w-6xl px-5 md:px-8">
      <div class="grid gap-6 md:gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          dx.features.map((f, i) => (
            <div class="reveal rounded-2xl border shadow-md p-6 sm:p-8" style={`border-color: var(--border); background-color: var(--bg-elevated); transition-delay: ${(i % 3) * 80}ms;`}>
              <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl mb-5" style="background-color: var(--accent-soft);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8M12 16v4"/></svg>
              </div>
              <h3 class="text-lg font-bold mb-2" style="color: var(--navy);">{f.title}</h3>
              <p class="text-sm md:text-base" style="color: var(--text-muted);">{f.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- メリット -->
  <section class="py-20 md:py-28" style="background-color: var(--bg-subtle);">
    <div class="mx-auto max-w-6xl px-5 md:px-8">
      <div class="grid gap-12 lg:gap-16 lg:grid-cols-2 items-center">
        <div class="reveal">
          <p class="text-xs md:text-sm tracking-[0.3em] mb-4 font-semibold eyebrow" style="color: var(--accent);">BENEFITS</p>
          <h2 class="heading" style="font-size: clamp(1.6rem, 4vw, 2.5rem);">DXがもたらす3つのメリット</h2>
          <ul class="mt-8 flex flex-col gap-4">
            {
              dx.benefits.map((b) => (
                <li class="flex items-start gap-3 text-base md:text-lg font-medium" style="color: var(--navy);">
                  <span class="inline-flex items-center justify-center w-7 h-7 rounded-full shrink-0 mt-0.5" style="background-color: var(--accent);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg>
                  </span>
                  {b}
                </li>
              ))
            }
          </ul>
        </div>
        <div class="reveal" style="transition-delay: 120ms;">
          <img src="/images/photos/service-03.jpg" alt="オンラインで相談する様子" width="800" height="600" loading="lazy" decoding="async" class="w-full h-auto rounded-3xl shadow-md" />
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
