---
import { testimonials } from '../data/site';
---

<section class="py-24 md:py-32" style="background-color: var(--bg-subtle);">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="reveal max-w-2xl mb-14 md:mb-16">
      <p class="text-xs md:text-sm tracking-[0.3em] mb-4 font-semibold eyebrow" style="color: var(--accent);">VOICE</p>
      <h2 class="heading" style="font-size: clamp(1.75rem, 4.5vw, 2.75rem);">お客様の声</h2>
    </div>

    <div class="grid gap-6 md:gap-8 md:grid-cols-3">
      {
        testimonials.map((t, i) => (
          <figure
            class="reveal flex flex-col rounded-2xl bg-white border p-8"
            style={`border-color: var(--border); transition-delay: ${i * 90}ms;`}
          >
            <div class="flex gap-1 mb-5" aria-label="5つ星の評価">
              {Array.from({ length: 5 }).map(() => (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--accent)" aria-hidden="true">
                  <path d="M12 2.5l2.9 5.9 6.5.9-4.7 4.6 1.1 6.5L12 17.8 6.2 20.9l1.1-6.5L2.6 9.3l6.5-.9L12 2.5z"/>
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-base leading-loose" style="color: var(--text-body);">「{t.body}」</blockquote>
            <figcaption class="mt-6 flex items-center gap-3">
              <span class="inline-flex items-center justify-center w-11 h-11 rounded-full text-sm font-bold" style="background-color: var(--navy-soft); color: var(--navy);">
                {t.name.charAt(0)}
              </span>
              <span>
                <span class="block text-sm font-bold" style="color: var(--navy);">{t.name}</span>
                <span class="block text-xs" style="color: var(--text-muted);">{t.role}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
    <p class="mt-8 text-xs" style="color: var(--text-muted);">※ 掲載内容はイメージです。実際のお客様の声に差し替えてください。</p>
  </div>
</section>
