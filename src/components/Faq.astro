---
import { faqs } from '../data/site';
---

<section class="py-24 md:py-32">
  <div class="mx-auto max-w-3xl px-5 md:px-8">
    <div class="reveal mb-12 md:mb-14 text-center">
      <p class="text-xs md:text-sm tracking-[0.3em] mb-4 font-semibold eyebrow" style="color: var(--accent);">FAQ</p>
      <h2 class="heading" style="font-size: clamp(1.75rem, 4.5vw, 2.75rem);">よくあるご質問</h2>
    </div>

    <div class="flex flex-col gap-4">
      {
        faqs.map((f, i) => (
          <details class="reveal group rounded-2xl border overflow-hidden" style={`border-color: var(--border); background-color: var(--bg); transition-delay: ${i * 60}ms;`}>
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none px-6 py-5">
              <span class="flex items-start gap-3 text-base font-bold" style="color: var(--navy);">
                <span style="color: var(--accent);">Q.</span>
                {f.q}
              </span>
              <span class="shrink-0 transition-transform duration-300 group-open:rotate-45" style="color: var(--accent);" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-5 -mt-1 text-sm md:text-base" style="color: var(--text-muted);">
              {f.a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
