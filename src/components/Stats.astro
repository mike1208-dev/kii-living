---
import { stats } from '../data/site';
---

<section class="py-16 md:py-20" style="background-color: var(--bg-subtle);">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
      {
        stats.map((s, i) => (
          <div
            class={`reveal text-center md:px-4 ${i > 0 ? 'md:border-l' : ''}`}
            style={`transition-delay: ${i * 80}ms; border-color: var(--border);`}
          >
            <p class="flex items-baseline justify-center gap-1">
              <span class="text-4xl md:text-5xl font-black" style="color: var(--navy);">{s.value}</span>
              <span class="text-lg md:text-xl font-bold whitespace-nowrap" style="color: var(--accent);">{s.unit}</span>
            </p>
            <p class="mt-2 text-sm" style="color: var(--text-muted);">{s.label}</p>
          </div>
        ))
      }
    </div>
    <p class="mt-8 text-center text-xs" style="color: var(--text-muted);">
      ※ 数値はイメージです。公開前に実績値へ差し替えてください。
    </p>
  </div>
</section>
