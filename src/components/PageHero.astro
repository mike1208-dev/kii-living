---
// 下層ページ共通のページ見出し（固定ヘッダーのオフセット込み）
interface Props {
  eyebrow: string; // 英字ラベル
  title: string; // 日本語見出し
  lead?: string;
  image?: string; // 背景画像（薄く敷く）
}
const { eyebrow, title, lead, image } = Astro.props;
---

<section class="relative overflow-hidden pt-32 md:pt-40 pb-14 md:pb-20" style="background-color: var(--bg-subtle);">
  {
    image && (
      <img
        src={image}
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
        style="opacity: 0.35;"
      />
    )
  }
  <!-- 可読性確保のためのオーバーレイ（左を濃く） -->
  {
    image && (
      <div
        class="absolute inset-0"
        aria-hidden="true"
        style="background: linear-gradient(90deg, var(--bg-subtle) 0%, color-mix(in srgb, var(--bg-subtle) 65%, transparent) 45%, transparent 100%);"
      />
    )
  }
  <!-- アクセントの淡いグロー -->
  <div
    class="absolute inset-0"
    aria-hidden="true"
    style="background: radial-gradient(60% 100% at 90% 0%, var(--accent-soft), transparent 60%);"
  >
  </div>
  <div class="relative mx-auto max-w-6xl px-5 md:px-8">
    <p class="reveal text-xs md:text-sm tracking-[0.3em] font-semibold mb-4 eyebrow" style="color: var(--accent);">
      {eyebrow}
    </p>
    <h1 class="reveal heading" style="color: var(--text); font-size: clamp(1.9rem, 5vw, 3.25rem); transition-delay: 60ms;">
      {title}
    </h1>
    {
      lead && (
        <p class="reveal mt-6 max-w-2xl text-base md:text-lg" style="color: var(--text-muted); transition-delay: 120ms;">
          {lead}
        </p>
      )
    }
  </div>
</section>
