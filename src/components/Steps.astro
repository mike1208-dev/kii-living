---
// 汎用ステップ表示（売却・購入ページの流れで再利用）
interface Step {
  step: string;
  title: string;
  description: string;
}
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---

<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
  {
    steps.map((f, i) => (
      <div
        class="reveal relative rounded-2xl border p-6 sm:p-7 lg:p-8"
        style={`border-color: var(--border); background-color: var(--bg); transition-delay: ${i * 80}ms;`}
      >
        <span class="text-xs font-bold tracking-widest" style="color: var(--accent);">{f.step}</span>
        <div class="mt-4 mb-4 inline-flex items-center justify-center w-12 h-12 rounded-full text-lg font-black" style="background-color: var(--navy); color:#fff;">
          {i + 1}
        </div>
        <h3 class="text-lg font-bold mb-2" style="color: var(--navy);">{f.title}</h3>
        <p class="text-sm" style="color: var(--text-muted);">{f.description}</p>
        {i < steps.length - 1 && (
          <span class="hidden lg:block absolute top-1/2 -right-3 text-2xl" style="color: var(--accent);" aria-hidden="true">
            ›
          </span>
        )}
      </div>
    ))
  }
</div>
