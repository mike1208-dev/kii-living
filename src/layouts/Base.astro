---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { company } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${company.name} | ${company.tagline}`,
  description = company.description,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/ogp.png', Astro.site);

// ── 構造化データ（RealEstateAgent / LocalBusiness）──
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  '@id': `${Astro.site}#organization`,
  name: company.name,
  description: company.description,
  url: Astro.site?.toString(),
  telephone: company.tel,
  email: company.email,
  image: ogImage.toString(),
  address: {
    '@type': 'PostalAddress',
    postalCode: company.address.postal.replace('〒', ''),
    addressRegion: company.address.region,
    addressLocality: company.address.locality,
    streetAddress: company.address.street,
    addressCountry: 'JP',
  },
  ...(company.address.latitude && company.address.longitude
    ? {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: company.address.latitude,
          longitude: company.address.longitude,
        },
      }
    : {}),
  areaServed: company.address.region,
  knowsAbout: ['不動産売買', '不動産仲介', 'リフォーム', '不動産DX', '住宅ローン'],
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#ffffff" />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={company.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Font：Noto Sans JP -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Header />
    <main id="top">
      <slot />
    </main>
    <Footer />

    <!-- スクロール連動の登場アニメーション（軽量・アイランド不要） -->
    <script>
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
